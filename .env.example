# Copy to .env.local for local uploads (npm run dev)
# Same values as Vercel project environment variables

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION=ap-south-1
AWS_S3_BUCKET=wallpaperassets
CLOUDFRONT_DOMAIN=d1wqpnbk3wcub7.cloudfront.net
IMAGE_TRANSFORM_PATTERN=/fit-in/{w}x{h}/

# Required for production Firestore reads on Vercel.
# Use a Firebase/Google service account with Firestore access.
FIREBASE_PROJECT_ID=wallez
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
